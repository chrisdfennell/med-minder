        <iq:permissions>
            <!-- Required by the reminder background service (ReminderService):
                 it registers a periodic temporal event and calls
                 Background.requestApplicationWake when a dose comes due. -->
            <iq:uses-permission id="Background"/>
        </iq:permissions>
    </iq:application>
</iq:manifest>
